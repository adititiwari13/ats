{
  "info": {
    "name": "ATS - Applicant Tracking System",
    "description": "Complete API collection for the ATS system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Candidate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"CANDIDATE\",\n  \"phone\": \"+1234567890\"\n}"
            }
          }
        },
        {
          "name": "Register - Recruiter",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Recruiter\",\n  \"email\": \"jane@company.com\",\n  \"password\": \"password123\",\n  \"role\": \"RECRUITER\"\n}"
            }
          }
        },
        {
          "name": "Register - Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@ats.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior Java Developer\",\n  \"description\": \"We are looking for an experienced Java developer to join our team.\",\n  \"company\": \"TechCorp\",\n  \"location\": \"New York, NY\",\n  \"requiredSkills\": \"Java, Spring Boot, Hibernate, REST, MySQL\",\n  \"salaryMin\": 80000,\n  \"salaryMax\": 120000,\n  \"jobType\": \"FULL_TIME\",\n  \"experienceLevel\": \"SENIOR\"\n}"
            }
          }
        },
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Search Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/search?keyword=java",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Filter Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/filter?location=New York&jobType=FULL_TIME&experienceLevel=SENIOR",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply for Job",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/applications/apply/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coverLetter\": \"I am excited about this opportunity...\"\n}"
            }
          }
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/applications/my-applications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get All Applications (Admin/Recruiter)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/applications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Update Application Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/applications/1/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"SHORTLISTED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Resume",
      "item": [
        {
          "name": "Upload Resume",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/resumes/upload",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/resume.pdf"
                }
              ]
            }
          }
        },
        {
          "name": "Get My Resume",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/resumes/my-resume",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/stats",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
